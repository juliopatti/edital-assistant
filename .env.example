# LLM Provider: "openai" ou "google"
LLM_PROVIDER=openai

# Modelo a usar (ex: gpt-4o-mini, gpt-4o, gemini-2.0-flash, gemini-1.5-pro)
LLM_MODEL=gpt-4o-mini

# Chaves de API
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...

# Temperatura do modelo (0.0 a 1.0)
LLM_TEMPERATURE=0.2

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=sua_chave_langsmith
LANGCHAIN_PROJECT=edital-assistant
